# Actual Hugging Face model to load.
LLM_MODEL=cyankiwi/Qwen3-Coder-30B-A3B-Instruct-AWQ-4bit

# Public model name exposed by the OpenAI-compatible API.
# Clients should send this name in the "model" field.
LLM_SERVED_MODEL_NAME=qwen3-coder

# Service bind address. 0.0.0.0 means listen on all network interfaces.
LLM_HOST=0.0.0.0

# Service port.
LLM_PORT=8000

# Weight / compute dtype. "auto" lets vLLM choose the most appropriate type.
LLM_DTYPE=float16

# Maximum fraction of GPU memory that vLLM may reserve.
# Leave some headroom for CUDA runtime and fragmentation.
LLM_GPU_MEMORY_UTILIZATION=0.92

# Maximum context window length.
# Larger values increase KV cache usage significantly.
LLM_MAX_MODEL_LEN=32768

# Maximum number of concurrent request sequences scheduled by vLLM.
LLM_MAX_NUM_SEQS=16

# Maximum total tokens allowed in a single scheduler batch.
# Affects throughput, latency, and memory usage.
LLM_MAX_NUM_BATCHED_TOKENS=16384

# Tensor parallel size. Use 1 for single-GPU deployment.
LLM_TENSOR_PARALLEL_SIZE=1

# Add X-Request-Id to responses for tracing and log correlation.
LLM_ENABLE_REQUEST_ID_HEADERS=true

# Disable FastAPI docs endpoints in production.
LLM_DISABLE_FASTAPI_DOCS=true

# Disable uvicorn access log because custom audit logs are already enabled.
LLM_DISABLE_UVICORN_ACCESS_LOG=true

# Whether to trust remote Python code from the model repository.
# Keep false unless the selected model explicitly requires it.
LLM_TRUST_REMOTE_CODE=false

# Whether to enable vLLM built-in request logging.
# Usually false when custom audit logging is used.
LLM_ENABLE_LOG_REQUESTS=false

# Optional comma-separated Bearer tokens for /v1/* endpoints.
# Example: key-a,key-b
LLM_API_KEYS=

# Extra raw CLI args passed through to vLLM.
# Example: --disable-log-stats
LLM_EXTRA_ARGS=

# Enable custom audit logging middleware.
AUDIT_LOG_ENABLED=true

# Comma-separated API paths included in audit logging.
AUDIT_LOG_PATHS=/v1/chat/completions,/v1/completions,/v1/responses

# Example OpenAI-compatible client base URL.
# Keep this port aligned with LLM_PORT.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1

# Example client API key. Must match one of LLM_API_KEYS if auth is enabled.
OPENAI_API_KEY=sk-local-vllm

# Example client model name. Should match LLM_SERVED_MODEL_NAME.
OPENAI_MODEL=qwen3-coder
