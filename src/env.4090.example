# 4090 24GB 部署时，代码骨架兼容，但模型通常需要量化版或更小模型。
# 建议将下方模型替换为量化权重或更小上下文配置后再上线。
LLM_MODEL=REPLACE_WITH_4090_FRIENDLY_MODEL
LLM_SERVED_MODEL_NAME=qwen3-coder
LLM_DTYPE=auto
LLM_GPU_MEMORY_UTILIZATION=0.9
LLM_MAX_MODEL_LEN=16384
LLM_MAX_NUM_SEQS=8
LLM_MAX_NUM_BATCHED_TOKENS=8192
LLM_TENSOR_PARALLEL_SIZE=1
LLM_EXTRA_ARGS=--disable-log-stats
