# 4090 24GB 部署时，代码骨架兼容，但模型通常需要量化版或更小模型。
# 建议将下方模型替换为量化权重或更小上下文配置后再上线。
VLLM_MODEL=REPLACE_WITH_4090_FRIENDLY_MODEL
VLLM_SERVED_MODEL_NAME=qwen3-coder
VLLM_DTYPE=auto
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=16384
VLLM_MAX_NUM_SEQS=8
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_EXTRA_ARGS=--disable-log-stats
