# 4090 24GB 单卡建议使用 4bit 量化版，并采用更保守的上下文和并发配置。
LLM_MODEL=cyankiwi/Qwen3-Coder-30B-A3B-Instruct-AWQ-4bit
LLM_SERVED_MODEL_NAME=qwen3-coder
LLM_DTYPE=float16
LLM_GPU_MEMORY_UTILIZATION=0.9
LLM_MAX_MODEL_LEN=16384
LLM_MAX_NUM_SEQS=4
LLM_MAX_NUM_BATCHED_TOKENS=4096
LLM_TENSOR_PARALLEL_SIZE=1
LLM_EXTRA_ARGS=--disable-log-stats
